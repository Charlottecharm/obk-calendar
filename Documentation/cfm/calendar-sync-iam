AWSTemplateFormatVersion: '2010-09-09'
Description: 'IAM roles and policies for Salesforce Calendar Sync'

Parameters:
  Environment:
    Type: String
    Default: prod
    AllowedValues: [prod]
    Description: Environment name

  SalesforceSecretName:
    Type: String
    Description: Name of the secret in Secrets Manager containing Salesforce credentials

Resources:
  # IAM Roles
  LambdaExecutionRole:
    Type: AWS::IAM::Role
    Properties:
      AssumeRolePolicyDocument:
        Version: '2012-10-17'
        Statement:
          - Effect: Allow
            Principal:
              Service: lambda.amazonaws.com
            Action: sts:AssumeRole
      ManagedPolicyArns:
        - arn:aws:iam::aws:policy/service-role/AWSLambdaBasicExecutionRole
      Policies:
        - PolicyName: DynamoDBAccess
          PolicyDocument:
            Version: '2012-10-17'
            Statement:
              - Effect: Allow
                Action:
                  - dynamodb:PutItem
                  - dynamodb:UpdateItem
                  - dynamodb:DeleteItem
                  - dynamodb:Query
                  - dynamodb:GetItem
                Resource: 
                  Fn::ImportValue: !Sub ${Environment}-CalendarEventsTableArn
        - PolicyName: SecretsManagerAccess
          PolicyDocument:
            Version: '2012-10-17'
            Statement:
              - Effect: Allow
                Action:
                  - secretsmanager:GetSecretValue
                Resource: !Sub arn:aws:secretsmanager:${AWS::Region}:${AWS::AccountId}:secret:${SalesforceSecretName}-*
      Tags:
        - Key: Environment
          Value: !Ref Environment
        - Key: Service
          Value: CalendarSync
        - Key: Component
          Value: IAM

Outputs:
  LambdaExecutionRoleArn:
    Description: ARN of the Lambda execution role
    Value: !GetAtt LambdaExecutionRole.Arn
    Export:
      Name: !Sub ${Environment}-LambdaExecutionRoleArn 
